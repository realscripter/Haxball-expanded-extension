{
  "manifest_version": 3,
  "name": "Haxball Extended",
  "version": "0.13",
  "description": "Verifies players and enhances Haxball rooms running the Extended server library.",
  "permissions": [],
  "host_permissions": [
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.haxball.com/*"],
      "js": [
        "modules/config.js",
        "modules/api.js",
        "modules/nick.js",
        "modules/title.js",
        "modules/lobby.js",
        "modules/dialog.js",
        "modules/commands.js",
        "modules/badge.js",
        "content.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}